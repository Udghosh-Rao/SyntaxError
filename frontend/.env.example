# Frontend Environment Variables (Vite)
# Copy to .env and fill in your actual values.
# All must start with VITE_ to be exposed to the browser.

# Backend API URL (leave empty in dev — Vite proxy handles /api)
VITE_API_BASE_URL=

# Algolia instant search (use SEARCH-ONLY API key — safe for browser)
VITE_ALGOLIA_APP_ID=your_algolia_app_id
VITE_ALGOLIA_SEARCH_KEY=your_algolia_search_only_api_key
VITE_ALGOLIA_INDEX=events

# Razorpay public key ID (safe for browser — no secret here)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
