# Backend API base URL (proxied by Vite in dev)
VITE_API_BASE_URL=/api

# Razorpay public key (same value as RAZORPAY_KEY_ID in backend/.env)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX

# Google OAuth client ID (same value as GOOGLE_CLIENT_ID in backend/.env)
VITE_GOOGLE_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
