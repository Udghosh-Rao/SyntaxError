# Sports Event Management — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Flask
SECRET_KEY=your-super-secret-key-change-this
FLASK_ENV=development

# Database
# Development: leave empty to use SQLite
# Production: set to PostgreSQL connection string
DATABASE_URL=

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Platform fee (15% = 0.15)
PLATFORM_FEE=0.15

# Price tier thresholds (INR)
PRICE_TIER_CHEAP_MAX=500
PRICE_TIER_MID_MAX=2000

# Algolia (get from https://dashboard.algolia.com)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_API_KEY=your_algolia_admin_api_key
ALGOLIA_INDEX=events

# OpenAI (primary LLM for chatbot)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional GenAI fallbacks
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=
