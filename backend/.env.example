# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# ── JWT ────────────────────────────────────────────────────
# (flask-jwt-extended uses SECRET_KEY by default)

# ── Razorpay ────────────────────────────────────────────────
# Leave as-is for sandbox/mock mode.
# Replace with your real credentials from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Platform fee taken from each transaction (default 5 %)
PLATFORM_FEE=0.05

# ── Google OAuth ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Authorised JS origins: http://localhost:5173
# Authorised redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com

# ── Algolia search ─────────────────────────────────────────
ALGOLIA_APP_ID=XXXXXXXXXX
ALGOLIA_API_KEY=admin_api_key

# ── OpenAI (chatbot) ───────────────────────────────────────
OPENAI_API_KEY=sk-xxx
